generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// DentalCare Pro - Prisma schema adaptado al UML de diseño mejorado.
// Se conservan nombres existentes en inglés para no romper frontend/backend actual.

model Employee {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  documentId      String    @unique
  email           String    @unique
  password        String
  phone           String?
  address         String?
  role            Role      @default(RECEPTIONIST)
  salary          Float?
  contractDate    DateTime  @default(now())
  licenseNumber   String?   // numeroColegiado para odontólogos
  failedAttempts  Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patients        Patient[]      @relation("DoctorPatients")
  appointments    Appointment[]  @relation("DoctorAppointments")
  procedures      ProcedureLog[] @relation("DoctorProcedures")
  clinicalNotes   ClinicalHistory[]
  shifts          ShiftAssignment[]
  auditLogs       AuditLog[]
  prescriptions   Prescription[]
  specialties     Specialty[] @relation("DoctorSpecialties")
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  NURSE
}

model Patient {
  id              String    @id @default(uuid())
  patientCode     String?   @unique
  firstName       String
  lastName        String
  birthDate       DateTime
  gender          String
  documentType    String
  documentNumber  String    @unique
  rtn             String?
  address         String?
  phone           String
  email           String?
  isActive        Boolean   @default(true)

  // DatosSalud existentes conservados para compatibilidad
  allergies       String?
  chronicDiseases String?
  medications     String?
  familyHistory   String?

  doctorId        String?
  doctor          Employee? @relation("DoctorPatients", fields: [doctorId], references: [id])
  responsibleId   String?
  responsible     Responsible? @relation(fields: [responsibleId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appointments    Appointment[]
  prescriptions   Prescription[]
  procedures      ProcedureLog[]
  clinicalHistory ClinicalHistory[]
  clinicalProcedures ClinicalHistoryProcedure[]
  files           PatientFile[]
  invoices        Invoice[]
  consents        Consent[]
}

model Responsible {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  relationship    String
  phone           String
  email           String?
  documentNumber  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patients        Patient[]
}

model ClinicalHistory {
  id                  String   @id @default(uuid())
  date                DateTime @default(now())
  reason              String?
  diagnosis           String
  treatmentPerformed  String?
  observations        String?
  status              String   @default("ACTIVE")

  patientId           String
  patient             Patient @relation(fields: [patientId], references: [id])

  odontologistId      String?
  odontologist        Employee? @relation(fields: [odontologistId], references: [id])

  appointmentId       String?
  appointment         Appointment? @relation(fields: [appointmentId], references: [id])

  procedureLogId      String?
  procedureLog        ProcedureLog? @relation(fields: [procedureLogId], references: [id])
  employeeId          String?
  shiftAssignmentId   String?
  procedures          ClinicalHistoryProcedure[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PatientFile {
  id              String   @id @default(uuid())
  fileName        String
  fileType        String
  fileUrl         String
  uploadedAt      DateTime @default(now())

  patientId       String
  patient         Patient @relation(fields: [patientId], references: [id])
}

model Appointment {
  id              String    @id @default(uuid())
  appointmentCode String?   @unique
  date            DateTime
  startTime       String?
  endTime         String?
  durationMinutes Int?
  status          AppointmentStatus @default(SCHEDULED)
  type            String
  description     String?
  diagnosis       String?
  treatment       String?
  observations    String?

  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Employee  @relation("DoctorAppointments", fields: [doctorId], references: [id])
  procedureTypeId String?
  procedureType   ProcedureType? @relation(fields: [procedureTypeId], references: [id])

  notifications   Notification[]
  clinicalHistory ClinicalHistory[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([doctorId, date])
  @@index([patientId, date])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  ATTENDED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

model Prescription {
  id              String    @id @default(uuid())
  correlative     Int       @unique
  date            DateTime  @default(now())
  status          String    @default("ACTIVE")
  patientId       String
  patient         Patient   @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Employee  @relation(fields: [doctorId], references: [id])
  items           PrescriptionItem[]
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PrescriptionItem {
  id              String    @id @default(uuid())
  drugName        String
  presentation    String
  dosage          String
  frequency       String
  duration        String
  prescriptionId  String
  prescription    Prescription @relation(fields: [prescriptionId], references: [id])
}

model ProcedureType {
  id              String    @id @default(uuid())
  procedureCode   String?   @unique
  name            String    @unique
  description     String?
  price           Float
  risks           String?
  category        String?
  estimatedDuration Int?
  taxType         String    @default("ISV_15")
  isActive        Boolean   @default(true)
  logs            ProcedureLog[]
  supplies        ProcedureSupply[]
  appointments    Appointment[]
  clinicalProcedures ClinicalHistoryProcedure[]
}

model ProcedureLog {
  id              String    @id @default(uuid())
  date            DateTime  @default(now())
  anesthesiaType  String?
  notes           String?
  status          ProcedureStatus @default(COMPLETED)

  procedureTypeId String
  procedureType   ProcedureType @relation(fields: [procedureTypeId], references: [id])
  patientId       String
  patient         Patient       @relation(fields: [patientId], references: [id])
  doctorId        String
  doctor          Employee      @relation("DoctorProcedures", fields: [doctorId], references: [id])

  consent         Consent?
  invoiceId       String?
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  clinicalHistory ClinicalHistory[]
}

model ClinicalHistoryProcedure {
  id              String   @id @default(uuid())
  procedureCode   String
  procedureName   String
  price           Float
  taxType         String   @default("ISV_15")
  billingStatus   String   @default("PENDING")
  performedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clinicalHistoryId String
  clinicalHistory   ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id])

  patientId       String
  patient         Patient @relation(fields: [patientId], references: [id])

  procedureTypeId String
  procedureType   ProcedureType @relation(fields: [procedureTypeId], references: [id])

  performedById   String?
  invoiceId       String?
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])

  invoiceItems    InvoiceItem[]

  @@index([patientId, billingStatus])
  @@index([clinicalHistoryId])
}

enum ProcedureStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Consent {
  id              String   @id @default(uuid())
  signedAt        DateTime @default(now())
  description     String
  documentUrl     String?
  signerName      String?
  signatureDataUrl String?
  status          String   @default("SIGNED")

  patientId       String
  patient         Patient @relation(fields: [patientId], references: [id])

  procedureLogId  String? @unique
  procedureLog    ProcedureLog? @relation(fields: [procedureLogId], references: [id])
}

model Shift {
  id              String    @id @default(uuid())
  shiftCode       String?   @unique
  name            String
  startTime       String
  endTime         String
  daysOfWeek      String?
  notes           String?
  isActive        Boolean   @default(true)
  assignments     ShiftAssignment[]
}

model ShiftAssignment {
  id              String    @id @default(uuid())
  date            DateTime
  endDate         DateTime?
  status          String    @default("ACTIVE")
  employeeId      String
  employee        Employee  @relation(fields: [employeeId], references: [id])
  shiftId         String
  shift           Shift     @relation(fields: [shiftId], references: [id])

  @@unique([date, employeeId, shiftId])
}

model Specialty {
  id          String @id @default(uuid())
  name        String @unique
  description String?
  doctors     Employee[] @relation("DoctorSpecialties")
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceCode   String?  @unique
  invoiceNumber String   @unique
  fiscalNumber  String?  @unique
  cai           String?
  rangeStart    Int?
  rangeEnd      Int?
  emissionDeadline DateTime?
  customerName  String?
  customerIdentity String?
  customerRtn   String?
  customerAddress String?
  taxable15     Float    @default(0)
  taxable18     Float    @default(0)
  exemptAmount  Float    @default(0)
  exoneratedAmount Float  @default(0)
  isv15         Float    @default(0)
  isv18         Float    @default(0)
  discountTotal Float    @default(0)
  totalInWords  String?
  paymentMethod String?
  notes         String?
  createdById   String?
  cancelledById String?
  cancelledAt   DateTime?
  cancellationReason String?
  issueDate     DateTime @default(now())
  subtotal      Float
  tax           Float    @default(0)
  total         Float
  status        String   @default("PENDING")

  patientId     String
  patient       Patient @relation(fields: [patientId], references: [id])
  fiscalRangeId String?
  fiscalRange   FiscalDocumentRange? @relation(fields: [fiscalRangeId], references: [id])

  items         InvoiceItem[]
  procedureLogs ProcedureLog[]
  clinicalProcedures ClinicalHistoryProcedure[]
  payments      Payment[]
}

model InvoiceItem {
  id              String   @id @default(uuid())
  description     String
  itemType        String
  itemCode        String?
  quantity        Int      @default(1)
  unitPrice       Float
  discount        Float    @default(0)
  taxType         String   @default("ISV_15")
  taxRate         Float    @default(0.15)
  taxAmount       Float    @default(0)
  taxable         Boolean  @default(true)
  tax             Float    @default(0)
  total           Float

  invoiceId       String
  invoice         Invoice @relation(fields: [invoiceId], references: [id])

  procedureLogId  String?
  clinicalHistoryProcedureId String?
  clinicalHistoryProcedure ClinicalHistoryProcedure? @relation(fields: [clinicalHistoryProcedureId], references: [id])
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
}

model FiscalDocumentRange {
  id                String   @id @default(uuid())
  documentType      String
  cai               String
  establishmentCode String
  emissionPointCode String
  documentTypeCode  String
  prefix            String?
  startNumber       Int
  endNumber         Int
  currentNumber     Int      @default(0)
  nextNumber        Int
  authorizationDate DateTime
  emissionDeadline  DateTime
  status            String   @default("ACTIVE")
  notes             String?
  createdById       String?
  updatedById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  invoices          Invoice[]

  @@index([documentType, status])
}

model Payment {
  id            String   @id @default(uuid())
  paymentDate   DateTime @default(now())
  amount        Float
  paymentMethod String
  reference      String?
  processor      String?
  status        String   @default("PAID")
  cancellationReason String?
  cancelledAt   DateTime?

  invoiceId     String
  invoice       Invoice @relation(fields: [invoiceId], references: [id])
}

model InventoryItem {
  id                String @id @default(uuid())
  inventoryCode     String? @unique
  name              String @unique
  description       String?
  quantityAvailable Int    @default(0)
  minimumStock      Int    @default(0)
  unitOfMeasure     String
  unitPrice         Float   @default(0)
  taxable           Boolean @default(true)
  isActive          Boolean @default(true)

  movements         InventoryMovement[]
  procedures        ProcedureSupply[]
  invoiceItems      InvoiceItem[]
}

model InventoryMovement {
  id            String   @id @default(uuid())
  movementType  String
  quantity      Int
  stockBefore   Int?
  stockAfter    Int?
  movementDate  DateTime @default(now())
  reason        String?
  reference     String?
  observations  String?
  userId        String?

  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model ProcedureSupply {
  id              String @id @default(uuid())
  quantityRequired Int @default(1)
  procedureTypeId String
  procedureType   ProcedureType @relation(fields: [procedureTypeId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([procedureTypeId, inventoryItemId])
}

model Notification {
  id              String   @id @default(uuid())
  type            String
  message         String
  sentAt          DateTime?
  status          String   @default("PENDING")

  appointmentId   String?
  appointment     Appointment? @relation(fields: [appointmentId], references: [id])

  createdAt       DateTime @default(now())
}

model AuditLog {
  id              String    @id @default(uuid())
  action          String
  entity          String
  entityId        String
  details         String?
  beforeData      String?
  afterData       String?
  ipAddress       String?
  timestamp       DateTime  @default(now())
  userId          String?
  user            Employee? @relation(fields: [userId], references: [id])
}
